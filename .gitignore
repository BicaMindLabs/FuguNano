# ── secrets — never enter the repo ───────────────────
# Local fugue-cc provider runtime/config/workspaces; never track.
.fugue-cc/
**/.fugue-cc/
*secrets*.env
cc-model-secrets.env
.env
.env.*

# ── runtime / cache ──────────────────────────────────
node_modules/
.claude-envs/*/opt/
*.log
.DS_Store

# ── desktop GUI packaged output (built locally, never tracked) ──
benchmarks/case-d-gui/desktop/release/

# ── fugue-cc provider runtime ─────────────────────────
.fugue-cc/state/
.fugue-cc/*.sock
.fugue-cc/logs/

# ── task / report artifacts ──────────────────────────
tasks/*.local.md
reports/

# Python bytecode
__pycache__/
*.pyc
