{
  "name": "fugunano-gui-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "FuguNano Studio — desktop GUI for the FuguNano orchestration loop",
  "author": "BicaMindLabs",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5180 && cross-env VITE_DEV=1 electron .",
    "dev": "concurrently -k -n renderer,electron -c magenta,blue \"npm:dev:renderer\" \"npm:dev:electron\"",
    "build": "vite build",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "package": "npm run build && npx --yes electron-builder@^25 --mac",
    "package:dir": "npm run build && npx --yes electron-builder@^25 --mac --dir"
  },
  "build": {
    "appId": "ai.bicamind.fugunano.studio",
    "productName": "FuguNano Studio",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "electron/**/*", "package.json"],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "category": "public.app-category.developer-tools",
      "identity": null
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "vitest": "^2.1.9",
    "wait-on": "^8.0.0"
  }
}
